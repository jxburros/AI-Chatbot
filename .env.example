# --- Single-connection setup (simplest) ---
# Provider selection (see lib/ai-config.ts for the full default-key-env map)
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

# API key — the env var name depends on AI_PROVIDER (OPENAI_API_KEY,
# ANTHROPIC_API_KEY, GOOGLE_API_KEY, GROQ_API_KEY, ...). Local runtimes
# (ollama/lmstudio/llamacpp/vllm) need no key.
OPENAI_API_KEY=

# Optional overrides
# AI_BASE_URL=http://localhost:11434
# AI_API_KEY_ENV=MY_CUSTOM_KEY_VAR

# --- Multi-connection setup (lets the chat UI's model picker switch between
# several providers) — set AI_CONNECTIONS instead of the AI_PROVIDER/AI_MODEL
# vars above. Each entry needs a `provider`; `keyEnv` defaults from
# lib/ai-config.ts's per-provider map if omitted. `defaultModel` is used
# when a provider's adapter doesn't support listModels() (anthropic and
# google both return [] today) so the connection still has a model to offer.
#
# AI_CONNECTIONS=[{"id":"openai","label":"OpenAI","provider":"openai","defaultModel":"gpt-4o-mini"},{"id":"anthropic","label":"Anthropic","provider":"anthropic","defaultModel":"claude-sonnet-5"},{"id":"ollama","label":"Local Ollama","provider":"ollama","baseUrl":"http://localhost:11434"}]
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
